# ============================================================
# Environment Variables — Sistem Dashboard Pemantauan Bersepadu JTM
# ============================================================
# Copy this file to `.env` for local dev, and set the same keys in
# Netlify → Site settings → Environment variables for production.
# ============================================================

# --- Local development database (Prisma + SQLite) ---
# Used by the dashboard preview so it runs offline.
DATABASE_URL=file:/home/z/my-project/db/custom.db

# --- Supabase (production backend, PRD §3.1 / §5) ---
# Public keys — safe for client-side, protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY

# Direct PostgreSQL connection (server-side only, e.g. for Prisma migrations).
# Find it in Supabase Dashboard → Project Settings → Database → Connection string.
# SUPABASE_DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres
